{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": false,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#F8F8F2",
          "background": "#6272A4",
          "properties": {
            "style": "short",
            "max_depth": 4,
            "home_icon": "~",
            "folder_icon": ""
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282A36",
          "background": "#50FA7B",
          "background_templates": [
            "{{ if or .Working.Changed .Staging.Changed }}#FFB86C{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#FF79C6{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "branch_icon": " "
          },
          "template": " {{ .HEAD }}{{ if .Working.Changed }} 󰷉{{ end }}{{ if .Staging.Changed }} 󱐌{{ end }}{{ if gt .Ahead 0 }} 󰜘{{ end }}{{ if gt .Behind 0 }} 󰜙{{ end }} "
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282A36",
          "background": "#FF79C6",
          "background_templates": [
            "{{ .Env.OMP_VIM_BG }}"
          ],
          "template": "{{ if eq .Env.OMP_VIM_MODE \"INSERT\" }} 󰗊 INSERT {{ else if eq .Env.OMP_VIM_MODE \"NORMAL\" }} 󰰓 NORMAL {{ else if eq .Env.OMP_VIM_MODE \"VISUAL\" }} 󰸿 VISUAL {{ else if eq .Env.OMP_VIM_MODE \"VISUAL LINE\" }} 󰸿 V-LINE {{ else if .Env.OMP_VIM_MODE }}  {{ .Env.OMP_VIM_MODE }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#F8F8F2",
          "background": "#44475A",
          "template": "{{ if .Env.OMP_MODEL }}  {{ .Env.OMP_MODEL }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282A36",
          "background": "#BD93F9",
          "template": "{{ if .Env.OMP_EFFORT }}{{ if eq .Env.OMP_EFFORT \"low\" }} 󰖔 low {{ else if eq .Env.OMP_EFFORT \"medium\" }} 󰖕 med {{ else if eq .Env.OMP_EFFORT \"high\" }} 󰖖 high {{ else if eq .Env.OMP_EFFORT \"xhigh\" }} 󰖗 xhigh {{ else if eq .Env.OMP_EFFORT \"max\" }} 󰖘 max {{ end }}{{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282A36",
          "background": "#6272A4",
          "background_templates": [
            "{{ .Env.OMP_CTX_BG }}"
          ],
          "template": "{{ if .Env.OMP_CTX_BAR }} ctx {{ .Env.OMP_CTX_BAR }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#F8F8F2",
          "background": "#44475A",
          "template": "{{ if .Env.OMP_RATE_5H }} 5h {{ .Env.OMP_RATE_5H }} {{ end }}"
        },
        {
          "type": "text",
          "style": "diamond",
          "trailing_diamond": "",
          "foreground": "#F8F8F2",
          "background": "#44475A",
          "template": "{{ if .Env.OMP_RATE_7D }} 7d {{ .Env.OMP_RATE_7D }} {{ end }}"
        }
      ]
    }
  ]
}
